{
  "name": "sketchbot-desktop",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm --prefix renderer run dev\" \"wait-on tcp:3001 && electron .\"",
    "build": "npm --prefix renderer run build",
    "start:renderer": "npm --prefix renderer run start",
    "electron": "electron ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "wait-on": "^8.0.5"
  }
}
