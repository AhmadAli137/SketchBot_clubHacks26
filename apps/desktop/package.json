{
  "name": "sayspark-desktop",
  "version": "1.0.0",
  "description": "AI-Tutored Robotics Platform",
  "author": "SaySpark",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm --prefix renderer run dev\" \"wait-on tcp:3001 && electron .\"",
    "build": "npm run build:renderer",
    "build:renderer": "npm --prefix renderer run build",
    "start:renderer": "npm --prefix renderer run start",
    "electron": "electron .",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron-builder": "^26.0.12",
    "electron": "37.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.sayspark.desktop",
    "productName": "SaySpark",
    "icon": "electron/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../services/local-runtime/app",
        "to": "local-runtime/app"
      },
      {
        "from": "../../services/local-runtime/data",
        "to": "local-runtime/data"
      },
      {
        "from": "../../services/local-runtime/python-dist",
        "to": "local-runtime/python-dist"
      },
      {
        "from": "../../services/local-runtime/requirements.txt",
        "to": "local-runtime/requirements.txt"
      }
    ],
    "asarUnpack": [
      "**/*.py"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://releases.sayspark.ca"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
