# ──────────────────────────────────────────────────────────────────────────────
# Aibotics Cloud Backend — environment variable template
#
# Copy this file to .env for local dev (already git-ignored).
# In production, set these as Render environment variables — NEVER commit real
# keys. No API key should ever appear in any app installer or client bundle.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=8010

# CORS — comma-separated allowed origins for browser clients
CLOUD_CORS_ORIGINS=http://127.0.0.1:3001,http://localhost:3001
CLOUD_CORS_ORIGIN_REGEX=^https://.*\.aibotics\.app$

# AI providers — server-side only, never sent to clients
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
OPENAI_API_KEY=

# Supabase — used to validate user JWTs on every AI request
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Set to true ONLY for local dev — disables JWT auth entirely
SKIP_AUTH=false

# Optional: override path to platform.json data file
SKETCHBOT_CLOUD_DATA_FILE=
