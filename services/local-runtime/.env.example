PORT=8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# ElevenLabs text-to-speech (used for Sketch voices "Mark" & "Lori")
ELEVENLABS_API_KEY=


# Optional: override the TTS model. Defaults to eleven_turbo_v2_5 (low-latency).
# Other good options: eleven_multilingual_v2 (higher quality), eleven_flash_v2_5
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
BACKEND_CORS_ORIGIN_REGEX=
WEBRTC_ICE_PROVIDER=static
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=
WEBRTC_ICE_SERVERS_JSON=
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TOKEN_TTL=3600

# Shown in teacher Feedback UI + used for mailto: links (classroom desktop)
DEVELOPER_CONTACT_EMAIL=hello@sketchbot.app

# Optional: sync tutor audit logs to Supabase (see scripts/supabase_tutor_audit.sql)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SYNC_DISABLE=0
